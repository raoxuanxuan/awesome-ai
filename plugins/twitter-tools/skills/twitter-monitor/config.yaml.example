settings:
  translate_non_chinese: true
  interval_minutes: 60
  lookback_minutes: 70
  first_run_lookback_minutes: 60
  max_scan_per_user: 50
  include_replies: false
  include_retweets: false
  expand_thread: true
  download_media: true
  mark_skipped_as_seen: true

sinks:
  obsidian:
    enabled: true
    prompt_prefix: "保存到 AI"
